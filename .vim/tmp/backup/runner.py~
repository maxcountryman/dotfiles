#! /usr/bin/env python

import os
import sys

import gevent
import yaml

from core.bot import Bot

if __name__ == '__main__':
    
    if not os.path.isfile('settings.yaml'):
        print 'Settings file not found!'
        sys.exit()

    settings = yaml.load_all(open('settings.yaml'))
    
    bot = lambda setting : Bot(setting)

    jobs = [gevent.spawn(bot, setting) for setting in settings]
    
    try:
        gevent.joinall(jobs)

    except Exception, e:
        print e
        sys.exit()
    
    finally: gevent.killall(jobs)
        sys.exit()
