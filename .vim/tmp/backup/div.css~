#wrapper {
    padding: 7px;
    border: 3px solid #777;
    margin-left: auto; 
    margin-right: auto;
    position: relative;
}

.left {
    border: 2px dotted #AAA;
    width: 45%;
    position: absolute;
    top: 7px;
    left: 7px;
}

.right {
    border: 2px dotted #AAA;
    width: 45%;
    position: absolute;
    top: 7px;
    right: 7px;
}
